    <content><![CDATA[<h2 id="导出FSimage"><a href="#导出FSimage" class="headerlink" title="导出FSimage"></a>导出FSimage</h2><figure class="highlight shell"><table><tr><td class="code"><pre><span class="line">[root@worker03 PGDataShop]$ mkdir metta</span><br><span class="line"></span><br><span class="line">[root@worker03 PGDataShop]$ hdfs dfsadmin -fetchImage metta/</span><br><span class="line"></span><br><span class="line">[root@worker03 metta]$ ll</span><br><span class="line">total 960808</span><br><span class="line">-rw-rw-r-- 1 root root 983861710 May 20 16:24 fsimage_0000000000616506859</span><br></pre></td></tr></table></figure>

<span id="more"></span>

<h2 id="将文件转换为csv"><a href="#将文件转换为csv" class="headerlink" title="将文件转换为csv"></a>将文件转换为csv</h2><figure class="highlight shell"><table><tr><td class="code"><pre><span class="line">[root@worker03 metta]$ hdfs oiv -i fsimage_0000000000616506859  -o fsimage.csv -p Delimited</span><br><span class="line">SLF4J: Class path contains multiple SLF4J bindings.</span><br><span class="line">SLF4J: Found binding in [jar:file:/opt/cloudera/parcels/CDH-6.3.2-1.cdh6.3.2.p0.1605554/jars/slf4j-log4j12-1.7.25.jar!/org/slf4j/impl/StaticLoggerBinder.class]</span><br><span class="line">SLF4J: Found binding in [jar:file:/opt/cloudera/parcels/CDH-6.3.2-1.cdh6.3.2.p0.1605554/jars/avro-tools-1.8.2-cdh6.3.2.jar!/org/slf4j/impl/StaticLoggerBinder.clas                                          s]</span><br><span class="line">SLF4J: Found binding in [jar:file:/opt/cloudera/parcels/CDH-6.3.2-1.cdh6.3.2.p0.1605554/jars/hive-jdbc-2.1.1-cdh6.3.2-standalone.jar!/org/slf4j/impl/StaticLoggerB                                          inder.class]</span><br><span class="line">SLF4J: Found binding in [jar:file:/opt/cloudera/parcels/CDH-6.3.2-1.cdh6.3.2.p0.1605554/jars/log4j-slf4j-impl-2.8.2.jar!/org/slf4j/impl/StaticLoggerBinder.class]</span><br><span class="line">SLF4J: Found binding in [jar:file:/opt/cloudera/parcels/CDH-6.3.2-1.cdh6.3.2.p0.1605554/jars/parquet-tools-1.9.0-cdh6.3.2.jar!/org/slf4j/impl/StaticLoggerBinder.c                                          lass]</span><br><span class="line">SLF4J: Found binding in [jar:file:/opt/cloudera/parcels/CDH-6.3.2-1.cdh6.3.2.p0.1605554/jars/slf4j-simple-1.7.25.jar!/org/slf4j/impl/StaticLoggerBinder.class]</span><br><span class="line">SLF4J: See http://www.slf4j.org/codes.html#multiple_bindings for an explanation.</span><br><span class="line">SLF4J: Actual binding is of type [org.slf4j.impl.Log4jLoggerFactory]</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.PBImageTextWriter: Loading string table</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.FSImageHandler: Loading 55 strings</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.PBImageTextWriter: Loading inode references</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.FSImageHandler: Loading inode references</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.FSImageHandler: Loaded 0 inode references</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.PBImageTextWriter: Loading directories</span><br><span class="line">21/05/20 16:25:32 INFO offlineImageViewer.PBImageTextWriter: Loading directories in INode section.</span><br><span class="line">21/05/20 16:25:54 INFO offlineImageViewer.PBImageTextWriter: Found 251012 directories in INode section.</span><br><span class="line">21/05/20 16:25:54 INFO offlineImageViewer.PBImageTextWriter: Finished loading directories in 21593ms</span><br><span class="line">21/05/20 16:25:54 INFO offlineImageViewer.PBImageTextWriter: Loading INode directory section.</span><br><span class="line">21/05/20 16:25:57 INFO offlineImageViewer.PBImageTextWriter: Scanned 241365 INode directories to build namespace.</span><br><span class="line">21/05/20 16:25:57 INFO offlineImageViewer.PBImageTextWriter: Finished loading INode directory section in 3721ms</span><br><span class="line">21/05/20 16:25:57 INFO offlineImageViewer.PBImageTextWriter: Found 8217157 INodes in the INode section</span><br><span class="line">21/05/20 16:28:35 INFO offlineImageViewer.PBImageTextWriter: Outputted 8217157 INodes.</span><br></pre></td></tr></table></figure>

<h2 id="将文件映射为Hive表"><a href="#将文件映射为Hive表" class="headerlink" title="将文件映射为Hive表"></a>将文件映射为Hive表</h2><figure class="highlight shell"><table><tr><td class="code"><pre><span class="line">[root@worker03 metta]$ hdfs dfs -copyFromLocal fsimage.csv /tmp/fsimage.csv</span><br></pre></td></tr></table></figure>

<figure class="highlight sql"><table><tr><td class="code"><pre><span class="line">## 创建meta表</span><br><span class="line"><span class="keyword">CREATE</span> <span class="keyword">EXTERNAL</span> <span class="keyword">TABLE</span> test.HDFS_META (</span><br><span class="line">	path STRING,</span><br><span class="line">	repl <span class="type">INT</span>,</span><br><span class="line">	ModificationTime STRING,</span><br><span class="line">	AccessTime STRING,</span><br><span class="line">	PreferredBlockSize <span class="type">INT</span>,</span><br><span class="line">	BlocksCount <span class="type">INT</span>,</span><br><span class="line">	FileSize <span class="type">INT</span>,</span><br><span class="line">	NSQUOTA <span class="type">INT</span>,</span><br><span class="line">	DSQUOTA <span class="type">INT</span>,</span><br><span class="line">	Permission STRING,</span><br><span class="line">	UserName STRING,</span><br><span class="line">	GroupName STRING </span><br><span class="line">) <span class="type">ROW</span> FORMAT DELIMITED FIELDS TERMINATED <span class="keyword">BY</span> <span class="string">&#x27;\t&#x27;</span> tblproperties (</span><br><span class="line">&quot;skip.header.line.count&quot; <span class="operator">=</span> &quot;1&quot;)</span><br><span class="line"></span><br><span class="line">## 加载数据</span><br><span class="line">load data inpath <span class="string">&#x27;/tmp/fsimage.csv&#x27;</span> overwrite <span class="keyword">into</span> <span class="keyword">table</span> test.hdfs_meta;</span><br><span class="line"></span><br><span class="line">## 统计<span class="keyword">sql</span></span><br><span class="line"><span class="keyword">SELECT</span></span><br><span class="line">	strleft ( path, instr( path, <span class="string">&#x27;/&#x27;</span>, <span class="number">1</span>, <span class="number">5</span> )<span class="operator">-</span> <span class="number">1</span> ) basepath,</span><br><span class="line">	<span class="built_in">sum</span>( blockscount ) blockscount,</span><br><span class="line">	<span class="built_in">sum</span>( filesize ) filesizes,</span><br><span class="line">	<span class="built_in">count</span>(<span class="operator">*</span>) file_nums </span><br><span class="line"><span class="keyword">FROM</span></span><br><span class="line">	hdfs_meta </span><br><span class="line"><span class="keyword">GROUP</span> <span class="keyword">BY</span></span><br><span class="line">	basepath </span><br><span class="line"><span class="keyword">ORDER</span> <span class="keyword">BY</span></span><br><span class="line">	blockscount <span class="keyword">DESC</span></span><br></pre></td></tr></table></figure>

<p><img src="../images/image-20210708172959118.png" alt="image-20220221181233652"></p>
